# Guardian secrets template — copy to .env.guardian and fill in real values.
# .env.guardian is gitignored and must never be committed.
#
# Generate strong values with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=guardian
POSTGRES_USER=guardian
POSTGRES_PASSWORD=<generate-with-secrets.token_hex(32)>
GUARDIAN_DB_PASSWORD=<same-as-POSTGRES_PASSWORD>
TASK_TOKEN_SECRET=<generate-with-secrets.token_hex(32)>
GUARDIAN_REQUIRE_AUTH=true
GUARDIAN_HOST=0.0.0.0
GUARDIAN_PORT=9766
TASK_TOKEN_ISSUER=legionforge
